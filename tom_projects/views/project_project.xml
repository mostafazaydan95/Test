<odoo>

<record id="project_project_form_inherit" model="ir.ui.view">
    <field name="name">project.project.form.inherit</field>
    <field name="model">project.project</field>    
    <field name="inherit_id" ref="project.edit_project"/>
    <field name="arch" type="xml">
      <data>
        <xpath expr="//form[1]/header[1]" position="inside">
         <!--  <field name="state" widget="statusbar" />
         <button name="155" type="action" class="oe_highlight" string="test" /> -->
          </xpath>

      <xpath expr="//button[@name='action_view_all_rating']" position="after">
        <button class="oe_stat_button" icon="fa-gears" type="object" name="action_view_configuration">
          <field name="tree_configurator_count" string="Settings" widget="statinfo"/>
        </button>
      </xpath>

        <xpath expr="//form[1]/sheet[1]/notebook[1]" position="inside">
          <page string="Tom Projects Details">
            <group>

              <group>
                <field name="date_start"/>
                <field name="date_end"/>
                <field name="land_area"/>
                <field name="trees_per_donum" />
                <field name="number_of_trees" />
              </group>

              <group>
                <field name="planting_type"/>
                <field name="irrigation_date"/>
                <field name="spraying_date"/>
                <field name="spraying_medication_date"/>

              </group>

            </group>
          </page>
        </xpath>
      </data>

    </field>
</record>

</odoo>
